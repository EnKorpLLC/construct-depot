{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "NEXTAUTH_URL": "REQUIRED",
    "NEXTAUTH_SECRET": "REQUIRED",
    "DATABASE_URL": "REQUIRED",
    "REDIS_URL": "REQUIRED"
  }
} 