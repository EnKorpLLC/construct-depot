# Test Environment Configuration

# API Configuration
API_URL=http://localhost:3000
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpass123

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bulkbuyer_test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bulkbuyer_test

# Redis Configuration
REDIS_URL=redis://localhost:6379
TEST_REDIS_URL=redis://localhost:6379

# Test Configuration
NODE_ENV=test
NEXT_PUBLIC_API_URL=http://localhost:3000
TEST_MODE=true

# Security
JWT_SECRET=test_jwt_secret_key_123
ENCRYPTION_KEY=test_encryption_key_456

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WS_URL=ws://localhost:3000/ws

# Analytics
ANALYTICS_ENABLED=true
METRICS_ENABLED=true 