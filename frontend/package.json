{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretest": "node -e \"require('./src/__tests__/utils/dependencyChecker').validateTestEnvironment(process.cwd())\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:quarantined": "jest --testNamePattern='^((?!@quarantined).)*$'",
    "test:fix-quarantined": "jest --testNamePattern='^.*@quarantined.*$'",
    "test:report": "node -e \"require('./src/__tests__/utils/testQuarantine').TestQuarantine.prototype.saveReport()\"",
    "test:clear-quarantine": "rm -f .test-quarantine.json && echo 'Quarantine cleared'",
    "test:load": "ts-node src/tests/load/run-load-tests.ts",
    "test:load:k6": "k6 run src/tests/load/load-test.ts",
    "test:load:ws": "ts-node src/tests/load/websocket-test.ts",
    "test:load:analytics": "k6 run -e API_URL=http://localhost:3000 -e TEST_USER_EMAIL=test@example.com -e TEST_USER_PASSWORD=testpass123 src/tests/load/analytics-load-test.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.15",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ioredis": "^5.3.2",
    "redis": "^4.6.12",
    "pg": "^8.11.3",
    "zod": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "@prisma/client": "^5.8.1",
    "nodemailer": "^6.9.8",
    "@react-email/components": "^0.0.12",
    "@react-email/render": "^0.0.9",
    "rate-limiter-flexible": "^3.0.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/redis": "^4.0.11",
    "@types/pg": "^8.10.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "jest-watch-typeahead": "^2.2.2",
    "node-mocks-http": "^1.13.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "prisma": "^5.8.1"
  }
}
