// This is your Prisma schema file
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Enable direct connections for local development
  directUrl = env("DIRECT_URL") // optional
}

generator client {
  provider        = "prisma-client-js"
  // Required for Neon serverless
  previewFeatures = ["driverAdapters"]
}

enum UserRole {
  ADMIN
  CUSTOMER
  GENERAL_CONTRACTOR
  SUBCONTRACTOR
  SUPPLIER
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  DRAFT
  POOLING      // Orders in pooling phase waiting for minimum quantity
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  WIRE_TRANSFER
  PURCHASE_ORDER
}

enum PoolStatus {
  OPEN
  CLOSED
  FULFILLED
  EXPIRED
  CANCELLED
}

enum PooledOrderStatus {
  OPEN // Accepting new orders
  LOCKED // MOQ reached, no new orders
  PROCESSING // Being processed by supplier
  COMPLETED // All orders fulfilled
  CANCELLED
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  password           String
  firstName          String
  lastName           String
  companyName        String?
  role               UserRole       @default(CUSTOMER)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  taxExempt          Boolean        @default(false)
  taxExemptionNumber String?
  taxAddress         Json?
  cartItems          CartItem[]
  orders             Order[]
  supplierOrders     Order[]        @relation("SupplierOrders")
  products           Product[]
  orderHistory       OrderHistory[]
  supplierPools      PoolGroup[]    @relation("SupplierPools")
  orderSettings      OrderSettings[]
  activityLogs       ActivityLog[]

  // Supplier specific fields
  supplierStatus      SupplierStatus?
  supplierApplication SupplierApplication?

  // NextAuth.js fields
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  CrawlerConfig CrawlerConfig[]

  @@index([email])
  @@index([role])
}

model SupplierApplication {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyDetails String   @db.Text
  businessType   String
  taxId          String
  websiteUrl     String?
  phoneNumber    String
  address        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  notes          String?  @db.Text
  documents      String[] // URLs to business documents
}

model Product {
  id               String        @id @default(cuid())
  name             String
  description      String        @db.Text
  price            Decimal       @db.Decimal(10, 2)
  minOrderQuantity Int
  unit             String // e.g., "pieces", "pallets", "cubic yards"
  supplierId       String
  supplier         User          @relation(fields: [supplierId], references: [id])
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  categories       String[]
  images           String[] // URLs to product images
  specifications   Json? // Flexible product specifications
  markup           Decimal       @default(1.20) @db.Decimal(10, 2) // 20% default markup
  orderItems       OrderItem[]
  pooledOrders     PooledOrder[]
  poolGroups       PoolGroup[]
  taxCode          String? // For product-specific tax codes
  cartItems        CartItem[]

  // Inventory tracking fields
  currentStock      Int            @default(0)
  lowStockThreshold Int            @default(10)
  inventoryStatus   String         @default("IN_STOCK") // IN_STOCK, LOW_STOCK, OUT_OF_STOCK
  inventoryLogs     InventoryLog[]
  reorderPoint      Int            @default(20)
  reorderQuantity   Int            @default(50)
  lastRestockDate   DateTime?

  @@index([name])
  @@index([categories])
  @@index([supplierId])
  @@index([isActive])
  @@index([inventoryStatus])
  @@index([currentStock])
  @@index([price])
  @@index([createdAt])
}

// New model for inventory tracking
model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String // RESTOCK, SALE, ADJUSTMENT, RETURN
  quantity  Int
  reason    String?  @db.Text
  createdAt DateTime @default(now())
  createdBy String // User ID who made the change
  reference String? // Order ID or other reference

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([createdBy])
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  userId          String
  supplierId      String
  status          OrderStatus    @default(DRAFT)
  totalAmount     Decimal        @db.Decimal(10, 2)
  currency        String         @default("USD")
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  poolExpiry      DateTime?      // Expiry time for pooling phase
  poolGroupId     String?        // Reference to pool group if order is pooled
  
  // Relations
  user            User           @relation(fields: [userId], references: [id])
  supplier        User           @relation("SupplierOrders", fields: [supplierId], references: [id])
  items           OrderItem[]
  payment         Payment?
  shipment        Shipment?
  history         OrderHistory[]
  poolGroup       PoolGroup?     @relation(fields: [poolGroupId], references: [id])
  pooledOrder     PooledOrder?   @relation(fields: [pooledOrderId], references: [id])
  pooledOrderId   String?
  
  // Indexes
  @@index([userId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
  @@index([poolExpiry])
  @@index([poolGroupId])
  @@index([pooledOrderId])
}

model PoolGroup {
  id                String      @id @default(cuid())
  productId         String
  supplierId        String
  status            PoolStatus  @default(OPEN)
  minQuantity       Int
  maxQuantity       Int?
  currentQuantity   Int         @default(0)
  expiryDate        DateTime
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orders            Order[]
  product           Product     @relation(fields: [productId], references: [id])
  supplier          User        @relation("SupplierPools", fields: [supplierId], references: [id])
  
  @@index([productId])
  @@index([supplierId])
  @@index([status])
  @@index([expiryDate])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  totalPrice  Decimal   @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  order       Order     @relation(fields: [orderId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  
  // Indexes
  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String         @id @default(cuid())
  orderId         String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  transactionId   String?
  paymentDetails  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  order           Order         @relation(fields: [orderId], references: [id])
  
  // Indexes
  @@index([status])
  @@index([createdAt])
}

model Shipment {
  id                String    @id @default(cuid())
  orderId           String    @unique
  trackingNumber    String?
  carrier           String?
  status            String
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  shippingAddress   Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  order             Order     @relation(fields: [orderId], references: [id])
  
  // Indexes
  @@index([status])
  @@index([trackingNumber])
}

model OrderHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  userId      String
  notes       String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  
  // Relations
  order       Order       @relation(fields: [orderId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  
  // Indexes
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
}

model OrderSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  defaultPaymentMethod String?
  defaultShippingAddr  Json?
  defaultBillingAddr   Json?
  notificationPrefs    Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                 User      @relation(fields: [userId], references: [id])
}

model PooledOrder {
  id             String            @id @default(cuid())
  status         PooledOrderStatus @default(OPEN)
  totalQuantity  Int
  startDate      DateTime          @default(now())
  endDate        DateTime? // When status changed from OPEN
  orders         Order[] // Related individual orders
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model StateTaxRate {
  id            String   @id @default(cuid())
  state         String   @unique
  stateCode     String   @unique @db.VarChar(2)
  rate          Decimal  @db.Decimal(5, 4) // Allows rates up to 99.99%
  hasLocalTax   Boolean  @default(false)
  effectiveDate DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CrawlerConfig {
  id          String       @id @default(cuid())
  name        String
  description String
  targetUrl   String
  schedule    String? // cron expression
  rateLimit   Int // requests per minute
  status      String // idle, running, completed, failed
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lastRunAt   DateTime?
  createdBy   String
  user        User         @relation(fields: [createdBy], references: [id])
  jobs        CrawlerJob[]

  @@index([createdBy])
}

model CrawlerJob {
  id             String        @id @default(cuid())
  configId       String
  config         CrawlerConfig @relation(fields: [configId], references: [id])
  startTime      DateTime      @default(now())
  endTime        DateTime?
  status         String // idle, running, completed, failed
  pagesProcessed Int           @default(0)
  itemsFound     Int           @default(0)
  errors         Json[] // Array of CrawlerError objects

  @@index([configId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Composite indexes for common queries
model ProductSearch {
  id          String   @id @default(cuid())
  productId   String
  searchText  String
  createdAt   DateTime @default(now())

  @@index([searchText, createdAt])
}

// Cache table for expensive computations
model ProductStats {
  id              String   @id @default(cuid())
  productId       String   @unique
  totalSales      Int      @default(0)
  averageRating   Float    @default(0)
  viewCount       Int      @default(0)
  lastCalculated  DateTime @default(now())

  @@index([totalSales])
  @@index([averageRating])
  @@index([viewCount])
}

// Rate limiting table
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  points    Int      @default(0)
  expire    DateTime

  @@index([key, expire])
}

// Cache invalidation triggers
/// The following triggers will be created in a migration:
/// - trigger_product_update: Invalidates cache when product is updated
/// - trigger_inventory_update: Updates product stats on inventory changes
/// - trigger_activity_log: Maintains activity history with pruning
