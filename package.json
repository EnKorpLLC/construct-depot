{
  "name": "bulk-buyer-group",
  "version": "1.0.0",
  "description": "Bulk Buyer Group Application",
  "main": "index.js",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-dev.ps1",
    "setup:env": "powershell -ExecutionPolicy Bypass -File .\\scripts\\update-profile.ps1",
    "cleanup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\cleanup.ps1",
    "cleanup:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\cleanup.ps1",
    "dev:clean": "npm run cleanup && next dev",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:redis": "ts-node scripts/test-redis.ts",
    "test:load": "ts-node frontend/src/tests/load/run-load-tests.ts",
    "test:load:k6": "k6 run frontend/src/tests/load/load-test.ts",
    "test:load:ws": "ts-node frontend/src/tests/load/websocket-test.ts",
    "test:load:analytics": "k6 run -e API_URL=http://localhost:3000 -e TEST_USER_EMAIL=test@example.com -e TEST_USER_PASSWORD=testpass123 frontend/src/tests/load/analytics-load-test.ts",
    "test:load:orders": "k6 run -e API_URL=http://localhost:3000 -e TEST_USER_EMAIL=test@example.com -e TEST_USER_PASSWORD=testpass123 frontend/src/tests/load/order-management-load-test.ts",
    "dev:test": "set NODE_ENV=test && next dev",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.17.15",
    "@types/bcryptjs": "^2.4.6",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.3.2",
    "next": "^14.0.4",
    "next-auth": "^4.24.5",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^4.7.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "k6": "^0.0.0",
    "mock-socket": "^9.3.1",
    "prisma": "^5.8.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
